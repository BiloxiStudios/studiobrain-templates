{
  "entity_type": "assembly",
  "version": "1.0",
  "sections": [
    {
      "id": "assembly_identity",
      "title": "Assembly Identity",
      "icon": "Layers",
      "columns": 2,
      "collapsed_default": false,
      "fields": [
        {
          "key": "id",
          "label": "Assembly ID",
          "ui_component": "read-only-text",
          "required": true,
          "auto_generate_from": "name",
          "placeholder": "auto-generated from name",
          "help": "Auto-generated: lowercase, spaces replaced with underscores"
        },
        {
          "key": "name",
          "label": "Display Name",
          "ui_component": "text",
          "required": true,
          "placeholder": "Hero Base Template"
        },
        {
          "key": "assembly_type",
          "label": "Assembly Type",
          "ui_component": "select",
          "required": true,
          "options": [
            { "value": "character", "label": "Character" },
            { "value": "prop", "label": "Prop" },
            { "value": "building", "label": "Building" }
          ]
        },
        {
          "key": "hierarchy_level",
          "label": "Hierarchy Level",
          "ui_component": "select",
          "required": true,
          "options": [
            { "value": "template", "label": "Template (root)" },
            { "value": "profile", "label": "Profile" },
            { "value": "variant", "label": "Variant" },
            { "value": "zombie_variant", "label": "Zombie / Transformation Variant" },
            { "value": "transformation_variant", "label": "Transformation Variant" }
          ],
          "help": "Template → Profile → Variant → Zombie. Max depth: 4."
        },
        {
          "key": "parent_assembly_id",
          "label": "Parent Assembly",
          "ui_component": "entity-selector",
          "reference_type": "assembly",
          "placeholder": "Search for parent assembly...",
          "max_selections": 1,
          "help": "Required for Profile, Variant, and Zombie tiers"
        },
        {
          "key": "inheritance_mode",
          "label": "Inheritance Mode",
          "ui_component": "select",
          "options": [
            { "value": "full", "label": "Full — inherit all unfilled slots from parent" },
            { "value": "selective", "label": "Selective — inherit only listed slots" },
            { "value": "none", "label": "None — standalone assembly" }
          ]
        },
        {
          "key": "source_entity_type",
          "label": "Source Entity Type",
          "ui_component": "select",
          "options": [
            { "value": "character", "label": "Character" },
            { "value": "item", "label": "Item" },
            { "value": "location", "label": "Location" }
          ]
        },
        {
          "key": "source_entity_id",
          "label": "Source Entity",
          "ui_component": "entity-selector",
          "reference_type": "dynamic",
          "reference_type_field": "source_entity_type",
          "placeholder": "Search for source entity...",
          "max_selections": 1
        },
        {
          "key": "description",
          "label": "Description",
          "ui_component": "textarea",
          "rows": 3,
          "column_span": 2,
          "placeholder": "Brief description of this assembly..."
        }
      ]
    },
