{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://studiobrain.biloxistudios.com/schemas/universe.json",
  "title": "StudioBrain Universe Document Schema",
  "description": "JSON Schema for the UNIVERSE document YAML frontmatter.",
  "allOf": [
    {
      "$ref": "./_base.json"
    }
  ],
  "properties": {
    "entity_type": {
      "const": "universe"
    },
    "name": {
      "type": "string",
      "description": "Universe display name."
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "setting": {
      "type": [
        "string",
        "null"
      ]
    },
    "time_period": {
      "type": [
        "string",
        "null"
      ]
    },
    "tone": {
      "type": [
        "string",
        "null"
      ]
    },
    "themes": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "districts": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "factions": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "key_characters": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "lore_documents": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "id",
    "entity_type",
    "template_version",
    "template_category",
    "created_date",
    "last_updated"
  ],
  "additionalProperties": true
}
