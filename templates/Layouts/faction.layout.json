{
  "entity_type": "faction",
  "version": "1.0",
  "sections": [
    {
      "id": "basic_information",
      "title": "Basic Information",
      "icon": "Shield",
      "columns": 2,
      "collapsed_default": false,
      "fields": [
        {
          "key": "id",
          "label": "Faction ID",
          "ui_component": "read-only-text",
          "auto_generate_from": "name",
          "required": true,
          "placeholder": "e.g., crimson_raiders",
          "help": "Auto-generated: lowercase, spaces replaced with underscores",
          "column_span": 1
        },
        {
          "key": "name",
          "label": "Faction Name",
          "ui_component": "text",
          "required": true,
          "placeholder": "Crimson Raiders",
          "column_span": 1
        },
        {
          "key": "faction_type",
          "label": "Faction Type",
          "ui_component": "select",
          "column_span": 1,
          "options": [
            { "value": "military", "label": "Military" },
            { "value": "corporate", "label": "Corporate" },
            { "value": "criminal", "label": "Criminal" },
            { "value": "religious", "label": "Religious" },
            { "value": "political", "label": "Political" },
            { "value": "mercenary", "label": "Mercenary" },
            { "value": "cult", "label": "Cult" },
            { "value": "rebel", "label": "Rebel" },
            { "value": "tribal", "label": "Tribal" },
            { "value": "other", "label": "Other" }
          ]
        },
        {
          "key": "status",
          "label": "Status",
          "ui_component": "select",
          "column_span": 1,
          "options": [
            { "value": "active", "label": "Active" },
            { "value": "defeated", "label": "Defeated" },
            { "value": "disbanded", "label": "Disbanded" },
            { "value": "reformed", "label": "Reformed" },
            { "value": "underground", "label": "Underground" },
            { "value": "archived", "label": "Archived" }
          ]
        },
        {
          "key": "power_level",
          "label": "Power Level",
          "ui_component": "select",
          "column_span": 1,
          "options": [
            { "value": "minimal", "label": "Minimal" },
            { "value": "low", "label": "Low" },
            { "value": "medium", "label": "Medium" },
            { "value": "high", "label": "High" },
            { "value": "dominant", "label": "Dominant" }
