        {
          "key": "start_time",
          "label": "Start Time",
          "ui_component": "text",
          "placeholder": "2024-06-01T12:00:00"
        },
        {
          "key": "end_time",
          "label": "End Time",
          "ui_component": "text",
          "placeholder": "2024-06-01T15:00:00"
        },
        {
          "key": "duration",
          "label": "Duration",
